{
  "nodeModulesDir": "auto",
  "tasks": {
    "build:client": "deno run -A scripts/build-client.ts",
    "dev:server": "deno run --watch -A main.ts",
    "watch:client": "deno run -A scripts/watch-client.ts",
    "dev": "deno task build:client && deno run -A scripts/dev.ts"
  },
  "imports": {
    "@better-auth/mongo-adapter": "npm:@better-auth/mongo-adapter@^1.6.23",
    "@std/assert": "jsr:@std/assert@1",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "better-auth": "npm:better-auth@^1.6.23",
    "hono": "npm:hono@^4.12.31",
    "mongodb": "npm:mongodb@^7.5.0"
  },
  "exclude": [
    "static/**/*.gen.*"
  ],
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom"
    ],
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended",
        "react",
        "jsx"
      ]
    }
  }
}
